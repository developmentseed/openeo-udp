{
  "id": "swbm",
  "summary": "Simple Water Bodies' Mapping (SWBM)",
  "description": "Detects surface water in Sentinel-2 L2A scenes using an OR-ensemble of three normalized-difference indices (MNDWI, NDWI, SWI). Water pixels render blue; non-water pixels render as 2x true colour. Thresholds default to the Sentinel Hub evalscript values (MNDWI_thr=0.1, NDWI_thr=0.2, SWI_thr=0.03) and may be calibrated per scene using the histogram inspection procedure described in the original script.",
  "parameters": [
    {
      "name": "time",
      "description": "Temporal range for data acquisition",
      "schema": {},
      "default": [
        "2022-08-01",
        "2022-08-31"
      ],
      "optional": true
    },
    {
      "name": "bounding_box",
      "description": "Spatial extent for Lake of Sainte-Croix",
      "schema": {},
      "default": {
        "west": 6.1,
        "south": 43.72,
        "east": 6.27,
        "north": 43.82
      },
      "optional": true
    },
    {
      "name": "bands",
      "description": "Sentinel-2 bands required for SWBM indices",
      "schema": {},
      "default": [
        "B02",
        "B03",
        "B04",
        "B08",
        "B11"
      ],
      "optional": true
    },
    {
      "name": "cloud_cover",
      "description": "Maximum cloud cover percentage",
      "schema": {},
      "default": 22,
      "optional": true
    },
    {
      "name": "MNDWI_thr",
      "description": "MNDWI water threshold (default 0.1 per Sentinel Hub evalscript)",
      "schema": {
        "type": "number"
      },
      "default": 0.1,
      "optional": true
    },
    {
      "name": "NDWI_thr",
      "description": "NDWI water threshold (default 0.2 per Sentinel Hub evalscript)",
      "schema": {
        "type": "number"
      },
      "default": 0.2,
      "optional": true
    },
    {
      "name": "SWI_thr",
      "description": "SWI water threshold (default 0.03 per Sentinel Hub evalscript)",
      "schema": {
        "type": "number"
      },
      "default": 0.03,
      "optional": true
    }
  ],
  "process_graph": {
    "loadcollection1": {
      "process_id": "load_collection",
      "arguments": {
        "bands": [
          "B02",
          "B03",
          "B04",
          "B08",
          "B11"
        ],
        "id": "SENTINEL2_L2A",
        "properties": {
          "eo:cloud_cover": {
            "process_graph": {
              "lte1": {
                "process_id": "lte",
                "arguments": {
                  "x": {
                    "from_parameter": "value"
                  },
                  "y": 22
                },
                "result": true
              }
            }
          }
        },
        "spatial_extent": {
          "west": 6.1,
          "south": 43.72,
          "east": 6.27,
          "north": 43.82
        },
        "temporal_extent": [
          "2022-08-01",
          "2022-08-31"
        ]
      }
    },
    "reducedimension1": {
      "process_id": "reduce_dimension",
      "arguments": {
        "data": {
          "from_node": "loadcollection1"
        },
        "dimension": "t",
        "reducer": {
          "process_graph": {
            "first1": {
              "process_id": "first",
              "arguments": {
                "data": {
                  "from_parameter": "data"
                }
              },
              "result": true
            }
          }
        }
      }
    },
    "applydimension1": {
      "process_id": "apply_dimension",
      "arguments": {
        "context": [
          {
            "from_parameter": "MNDWI_thr"
          },
          {
            "from_parameter": "NDWI_thr"
          },
          {
            "from_parameter": "SWI_thr"
          }
        ],
        "data": {
          "from_node": "reducedimension1"
        },
        "dimension": "spectral",
        "process": {
          "process_graph": {
            "arraycreate1": {
              "process_id": "array_create",
              "arguments": {
                "data": [
                  0,
                  0,
                  1
                ]
              }
            },
            "arrayelement1": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "data"
                },
                "index": 2
              }
            },
            "divide1": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "arrayelement1"
                },
                "y": 10000
              }
            },
            "multiply1": {
              "process_id": "multiply",
              "arguments": {
                "x": {
                  "from_node": "divide1"
                },
                "y": 2
              }
            },
            "arrayelement2": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "data"
                },
                "index": 1
              }
            },
            "divide2": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "arrayelement2"
                },
                "y": 10000
              }
            },
            "multiply2": {
              "process_id": "multiply",
              "arguments": {
                "x": {
                  "from_node": "divide2"
                },
                "y": 2
              }
            },
            "arrayelement3": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "data"
                },
                "index": 0
              }
            },
            "divide3": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "arrayelement3"
                },
                "y": 10000
              }
            },
            "multiply3": {
              "process_id": "multiply",
              "arguments": {
                "x": {
                  "from_node": "divide3"
                },
                "y": 2
              }
            },
            "arraycreate2": {
              "process_id": "array_create",
              "arguments": {
                "data": [
                  {
                    "from_node": "multiply1"
                  },
                  {
                    "from_node": "multiply2"
                  },
                  {
                    "from_node": "multiply3"
                  }
                ]
              }
            },
            "arrayelement4": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "data"
                },
                "index": 4
              }
            },
            "divide4": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "arrayelement4"
                },
                "y": 10000
              }
            },
            "subtract1": {
              "process_id": "subtract",
              "arguments": {
                "x": {
                  "from_node": "divide2"
                },
                "y": {
                  "from_node": "divide4"
                }
              }
            },
            "add1": {
              "process_id": "add",
              "arguments": {
                "x": {
                  "from_node": "divide2"
                },
                "y": {
                  "from_node": "divide4"
                }
              }
            },
            "divide5": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "subtract1"
                },
                "y": {
                  "from_node": "add1"
                }
              }
            },
            "arrayelement5": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "context"
                },
                "index": 0
              }
            },
            "gt1": {
              "process_id": "gt",
              "arguments": {
                "x": {
                  "from_node": "divide5"
                },
                "y": {
                  "from_node": "arrayelement5"
                }
              }
            },
            "arrayelement6": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "data"
                },
                "index": 3
              }
            },
            "divide6": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "arrayelement6"
                },
                "y": 10000
              }
            },
            "subtract2": {
              "process_id": "subtract",
              "arguments": {
                "x": {
                  "from_node": "divide2"
                },
                "y": {
                  "from_node": "divide6"
                }
              }
            },
            "add2": {
              "process_id": "add",
              "arguments": {
                "x": {
                  "from_node": "divide2"
                },
                "y": {
                  "from_node": "divide6"
                }
              }
            },
            "divide7": {
              "process_id": "divide",
              "arguments": {
                "x": {
                  "from_node": "subtract2"
                },
                "y": {
                  "from_node": "add2"
                }
              }
            },
            "arrayelement7": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "context"
                },
                "index": 1
              }
            },
            "gt2": {
              "process_id": "gt",
              "arguments": {
                "x": {
                  "from_node": "divide7"
                },
                "y": {
                  "from_node": "arrayelement7"
                }
              }
            },
            "or1": {
              "process_id": "or",
              "arguments": {
                "x": {
                  "from_node": "gt1"
                },
                "y": {
                  "from_node": "gt2"
                }
              }
            },
            "subtract3": {
              "process_id": "subtract",
              "arguments": {
                "x": {
                  "from_node": "divide3"
                },
                "y": {
                  "from_node": "divide4"
                }
              }
            },
            "power1": {
              "process_id": "power",
              "arguments": {
                "base": {
                  "from_node": "subtract3"
                },
                "p": 0.5
              }
            },
            "divide8": {
              "process_id": "divide",
              "arguments": {
                "x": 1,
                "y": {
                  "from_node": "power1"
                }
              }
            },
            "arrayelement8": {
              "process_id": "array_element",
              "arguments": {
                "data": {
                  "from_parameter": "context"
                },
                "index": 2
              }
            },
            "gt3": {
              "process_id": "gt",
              "arguments": {
                "x": {
                  "from_node": "divide8"
                },
                "y": {
                  "from_node": "arrayelement8"
                }
              }
            },
            "or2": {
              "process_id": "or",
              "arguments": {
                "x": {
                  "from_node": "or1"
                },
                "y": {
                  "from_node": "gt3"
                }
              }
            },
            "if1": {
              "process_id": "if",
              "arguments": {
                "accept": {
                  "from_node": "arraycreate1"
                },
                "reject": {
                  "from_node": "arraycreate2"
                },
                "value": {
                  "from_node": "or2"
                }
              },
              "result": true
            }
          }
        }
      }
    },
    "apply1": {
      "process_id": "apply",
      "arguments": {
        "data": {
          "from_node": "applydimension1"
        },
        "process": {
          "process_graph": {
            "linearscalerange1": {
              "process_id": "linear_scale_range",
              "arguments": {
                "inputMax": 1,
                "inputMin": 0,
                "outputMax": 255,
                "outputMin": 0,
                "x": {
                  "from_parameter": "x"
                }
              },
              "result": true
            }
          }
        }
      }
    },
    "saveresult1": {
      "process_id": "save_result",
      "arguments": {
        "data": {
          "from_node": "apply1"
        },
        "format": "PNG",
        "options": {}
      },
      "result": true
    }
  }
}