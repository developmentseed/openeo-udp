              "process_id": "and",
              "arguments": {
                "x": {
                  "from_node": "gt1"
                },
                "y": {
                  "from_node": "lte2"
                }
              }
            },
            "if1": {
              "process_id": "if",
              "arguments": {
                "accept": {
                  "from_node": "add3"
                },
                "reject": 1.0,
                "value": {
                  "from_node": "and1"
                }
              }
            },
            "gt2": {
              "process_id": "gt",
              "arguments": {
                "x": {
                  "from_node": "divide3"
                },
                "y": -1.0
              }
            },
            "lte3": {
              "process_id": "lte",
              "arguments": {
                "x": {
                  "from_node": "divide3"
                },
                "y": 1.0
              }
            },
            "and2": {
              "process_id": "and",
              "arguments": {
                "x": {
                  "from_node": "gt2"
                },
                "y": {
                  "from_node": "lte3"
                }
              }
            },
            "if2": {
              "process_id": "if",
              "arguments": {
                "accept": {
                  "from_node": "multiply2"
                },
                "reject": {
                  "from_node": "if1"
                },
                "value": {
                  "from_node": "and2"
                }
              }
            },
            "lte4": {
              "process_id": "lte",
              "arguments": {
                "x": {
                  "from_node": "divide3"
                },
                "y": -1.0
              }
            },
            "if3": {
              "process_id": "if",
              "arguments": {
                "accept": 0.0,
                "reject": {
                  "from_node": "if2"
                },
                "value": {
                  "from_node": "lte4"
                }
              },
              "result": true
            }
          }
        }
      }
    },
    "apply1": {
      "process_id": "apply",
      "arguments": {
        "data": {
